# ── Camera ────────────────────────────────────────────────────────────────────

# Local IP address of the Reolink camera or NVR
CAMERA_IP=192.168.1.100

# Credentials configured in the Reolink app under Device Settings → User Management
CAMERA_USERNAME=admin
CAMERA_PASSWORD=secret

# Name of the PTZ preset to move to before each snapshot (must match exactly as saved in the Reolink app)
CAMERA_PRESET_NAME=full garden

# Optional: PTZ preset to return to after each snapshot. Leave unset to stay at the capture position.
CAMERA_HOME_PRESET=

# Channel index. 0 for single-camera setups; use the channel number for NVRs with multiple cameras.
CAMERA_CHANNEL=0

# Seconds to wait after moving to the preset before taking the snapshot.
# Increase if the camera hasn't fully settled before the image is captured.
PTZ_SETTLE_DELAY=4

# PTZ movement speed (1–64). Higher values move the camera faster.
PTZ_SPEED=32


# ── Scheduling ────────────────────────────────────────────────────────────────

# How often to capture a snapshot, in minutes
SNAPSHOT_INTERVAL=15

# If true, snapshots are taken around the clock. If false, captures are skipped during night hours.
SNAPSHOT_24_7=true


# ── Location ──────────────────────────────────────────────────────────────────
# Used to calculate local sunrise and sunset times for snapshot labeling.

# Decimal latitude (positive = north, negative = south)
LATITUDE=41.8781

# Decimal longitude (positive = east, negative = west)
LONGITUDE=-87.6298

# IANA timezone name for your camera's location (e.g. America/Chicago, Europe/London)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Chicago

# Minutes before/after sunrise and sunset during which snapshots are labeled "sunrise" or "sunset"
# instead of "day" or "night". Set to 0 to disable the transition window.
SUNRISE_SUNSET_WINDOW=30


# ── Timelapse ─────────────────────────────────────────────────────────────────

# If false, night-labeled snapshots are excluded from the daily timelapse video
TIMELAPSE_INCLUDE_NIGHT=true

# Frames per second for the generated timelapse video
TIMELAPSE_FPS=24

# Number of days to keep full daily timelapse MP4s. Older files are pruned unless they fall on an archive interval.
# Examples:
#   TIMELAPSE_RETENTION_DAYS=1  → only the most recent timelapse is kept (set TIMELAPSE_RETAIN_ALL=false)
#   TIMELAPSE_RETENTION_DAYS=7  → keep the last 7 days of daily files (default)
TIMELAPSE_RETENTION_DAYS=7

# One timelapse per this many days is archived indefinitely beyond the retention window.
# Files older than TIMELAPSE_RETENTION_DAYS are deleted unless their age is an exact multiple of this value.
# e.g. with RETENTION_DAYS=7 and ARCHIVE_EVERY=7, you keep 7 daily files plus one per week going back forever.
# e.g. with RETENTION_DAYS=1 and ARCHIVE_EVERY=1, you keep only today's file plus one per day going back forever.
TIMELAPSE_ARCHIVE_EVERY=7

# If true, all timelapse MP4s are kept forever and no pruning occurs. Overrides RETENTION_DAYS and ARCHIVE_EVERY.
TIMELAPSE_RETAIN_ALL=false

# If true, align each frame to the first frame using OpenCV feature matching (ORB + homography).
# Recommended for PTZ cameras to correct framing differences between captures.
# Automatically crops to the largest region covered by all aligned frames.
TIMELAPSE_ALIGN=true

# If true, apply video stabilization to each timelapse using libvidstab (two-pass).
# Not recommended for PTZ cameras with large intentional moves — use TIMELAPSE_ALIGN instead.
# If stabilization fails, the build falls back to an unstabilized video automatically.
TIMELAPSE_STABILIZE=false

# Percentage of the frame to crop from each edge after stabilization to remove border distortion.
# e.g. 5 removes 5% from each side (10% total width/height). Set to 0 to disable cropping.
TIMELAPSE_STABILIZE_CROP=5

# How much to smooth the camera path across frames (0–100). Lower values preserve more of the
# original motion; higher values smooth more aggressively. For PTZ cameras with intentional large
# moves, keep this low (1–5) to avoid warping frames that don't fit a smoothed trajectory.
TIMELAPSE_STABILIZE_SMOOTHING=5

# How aggressively to detect motion between frames (1–10). Lower values only correct subtle jitter;
# higher values correct larger shifts. For PTZ cameras, 3–5 is usually sufficient.
TIMELAPSE_STABILIZE_SHAKINESS=5

# If true, embed a subtitle track with the timestamp of each frame (visible in players like VLC).
TIMELAPSE_SUBTITLES=true

# Show a subtitle entry every N frames. 1 = every frame, 5 = every 5th frame, etc.
# Useful for reducing subtitle density in long timelapses.
TIMELAPSE_SUBTITLE_EVERY=1

# If true, burn a visible timestamp into the bottom-right corner of the video.
# Unlike TIMELAPSE_SUBTITLES, this is permanently visible and cannot be toggled by the viewer.
# The timestamp appears for 5 seconds of playback then fades out until the next update.
TIMELAPSE_BURNIN=false

# How often to update the burned-in timestamp, in real-world minutes of captured time.
# e.g. 30 = show a new timestamp for every 30 minutes of real time that passes between snapshots.
TIMELAPSE_BURNIN_EVERY=30


# ── Output ────────────────────────────────────────────────────────────────────

# Directory where dated snapshot folders will be created (e.g. /data/snapshots/2026-05-01/)
SNAPSHOT_DIR=/data/snapshots

# Directory where daily timelapse MP4 files will be saved
TIMELAPSE_DIR=/data/timelapse
