# Camera
CAMERA_IP=192.168.1.100
CAMERA_USERNAME=admin
CAMERA_PASSWORD=secret
CAMERA_PRESET_NAME=full garden
# Optional: preset to return to after each snapshot (leave unset to stay at capture position)
CAMERA_HOME_PRESET=
PTZ_SETTLE_DELAY=4

# Scheduling
SNAPSHOT_INTERVAL=15
SNAPSHOT_24_7=true

# Location (for sunrise/sunset calculation)
LATITUDE=41.8781
LONGITUDE=-87.6298
TIMEZONE=America/Chicago
# Minutes before/after sunrise and sunset to label snapshots as "sunrise" or "sunset" instead of "day" or "night"
SUNRISE_SUNSET_WINDOW=30

# Timelapse
TIMELAPSE_INCLUDE_NIGHT=true
TIMELAPSE_FPS=24

# Output
SNAPSHOT_DIR=/data/snapshots
TIMELAPSE_DIR=/data/timelapse
